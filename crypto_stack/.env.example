# Environment Configuration for crypto_stack

# Ethereum RPC URL (use a free one or your own)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/demo

# Registry Contract Address
REGISTRY_ADDRESS=0xD1E5b0FF1287aA9f9A268759062E4Ab08b9Dacbe

# Redis Configuration
REDIS_URL=redis://redis:6379

# Cloudflare Configuration (optional - for worker deployment)
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_ZONE_ID=your_zone_id_here

# DNS Server (requires root)
ENABLE_DNS=false

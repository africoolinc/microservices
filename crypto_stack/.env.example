# .crypto Domain Resolution Service - Environment Configuration
# Copy this to .env and fill in your values

# Ethereum RPC URL (Infura, Alchemy, or other provider)
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Registry Contract Address (DO NOT CHANGE - this is .crypto registry)
REGISTRY_ADDRESS=0xD1E5b0FF1287aA9f9A268759062E4Ab08b9Dacbe

# Redis Configuration
REDIS_URL=redis://redis:6379

# Cache TTL (in seconds)
CACHE_TTL=300

# Log Level
LOG_LEVEL=info

# Domain for this deployment
DOMAIN=mamaduka.crypto

# Ethereum RPC Provider
# Get a free key from https://www.alchemy.com/, https://infura.io/, or use public RPCs
ETH_RPC_URL=https://eth.llamarpc.com

# .Crypto Registry Contract (do not change)
REGISTRY_ADDRESS=0xD1E5b0FF1287aA9f9A268759062E4Ab08b9Dacbe

# Cache TTL in seconds
CACHE_TTL=300

# Redis URL (optional - leave empty for in-memory cache)
REDIS_URL=redis://cache:6379

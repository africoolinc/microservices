# BTC Options API Configuration
# Copy to .env and update with your API keys

# Redis
REDIS_URL=redis://redis:6379

# Deribit API (optional - for live trading)
DERIBIT_API_URL=https://www.deribit.com/api/v2
DERIBIT_KEY=your_deribit_key
DERIBIT_SECRET=your_deribit_secret

# Trading Config
SURGE_THRESHOLD=0.05
CONFIDENCE_THRESHOLD=0.70
POSITION_SIZE_PCT=0.02
STOP_LOSS_PCT=0.50

# Log Level
LOG_LEVEL=info
